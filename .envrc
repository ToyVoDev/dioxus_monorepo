use flake .
dotenv
# macOS 26 (Tahoe) SDK dropped arm64-macos from TBD files (only arm64e-macos remains).
# Nix cctools ld 1010.6 can't resolve arm64 symbols against arm64e-only TBDs.
# Unsetting DEVELOPER_DIR lets the Nix clang wrapper use its built-in SDK 14.4,
# which still has arm64-macos TBD entries and makes linking work.
unset DEVELOPER_DIR
